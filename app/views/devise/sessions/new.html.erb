<% content_for :title, "Вход — СМЫСЛ" %>

<div class="auth-page">
  <header class="auth-page__header">
    <%= link_to "← на главную", root_path, class: "auth-page__back" %>
    <h1 class="auth-page__title">С&nbsp;возвращением в&nbsp;смысл</h1>
  </header>

  <section class="auth-card">
    <h2 class="auth-card__title">Личный кабинет</h2>
    <p class="auth-card__lead">Здесь ждут твои ТЗ, расчёты бюджета и&nbsp;статьи, которые помогли разобраться. Войди, чтобы продолжить.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <label class="auth-field">
        <span>Email</span>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true %>
      </label>

      <label class="auth-field">
        <span>Пароль</span>
        <div class="auth-password">
          <%= f.password_field :password, autocomplete: "current-password", required: true, id: "login-password" %>
          <button type="button" class="auth-password__toggle" id="login-password-toggle" aria-label="Показать пароль" aria-pressed="false" onclick="(function(b){var i=document.getElementById('login-password');if(i.type==='password'){i.type='text';b.setAttribute('aria-label','Скрыть пароль');}else{i.type='password';b.setAttribute('aria-label','Показать пароль');}})(this)">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
      </label>

      <%= f.submit "Войти", class: "btn btn--primary auth-submit" %>
    <% end %>

    <p class="auth-secondary">
      <span>Ещё не с&nbsp;нами?</span>
      <%= link_to "Зарегистрироваться", new_registration_path(resource_name), class: "auth-link" %>
    </p>

    <% if devise_mapping.recoverable? && controller_name != "passwords" %>
      <p class="auth-secondary">
        <%= link_to "Забыл пароль", new_password_path(resource_name), class: "auth-link" %>
      </p>
    <% end %>
  </section>
</div>
