<% content_for :title, "Регистрация — СМЫСЛ" %>

<div class="auth-page">
  <header class="auth-page__header">
    <%= link_to "← на главную", root_path, class: "auth-page__back" %>
    <h1 class="auth-page__title">Добро пожаловать в&nbsp;смысл</h1>
  </header>

  <section class="auth-card">
    <h2 class="auth-card__title">Регистрация</h2>
    <p class="auth-card__lead">Заведём кабинет, чтобы сохранять твои ТЗ, расчёты и&nbsp;закладки. Минимум данных, без спама.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <% if resource.errors.any? %>
        <div style="padding: 12px 14px; border: 1px solid rgba(243, 182, 182, 0.55); color: #f3b6b6; font-size: 14px;">
          <% resource.errors.full_messages.each do |msg| %>
            <p style="margin: 4px 0;"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <label class="auth-field">
        <span>Email</span>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true %>
      </label>

      <label class="auth-field">
        <span>Пароль</span>
        <%= f.password_field :password, autocomplete: "new-password", required: true %>
        <% if @minimum_password_length %>
          <span style="font-size: 13px; opacity: 0.65;">минимум <%= @minimum_password_length %> символов</span>
        <% end %>
      </label>

      <label class="auth-field">
        <span>Пароль ещё раз</span>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true %>
      </label>

      <%= f.submit "Создать аккаунт", class: "btn btn--primary auth-submit" %>
    <% end %>

    <p class="auth-secondary">
      <span>Уже с&nbsp;нами?</span>
      <%= link_to "Войти", new_session_path(resource_name), class: "auth-link" %>
    </p>
  </section>
</div>
