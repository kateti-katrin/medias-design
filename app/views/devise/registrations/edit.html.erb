<h2><%= t("devise.registrations.edit.title", default: "Редактирование аккаунта") %></h2>

<% resource.build_profile if resource.profile.nil? %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <%= f.fields_for :profile do |pf| %>
    <div class="field">
      <%= pf.label :display_name %><br />
      <%= pf.text_field :display_name, autocomplete: "nickname" %>
    </div>

    <div class="field">
      <%= pf.label :bio %><br />
      <%= pf.text_area :bio, rows: 4 %>
    </div>

    <div class="field">
      <%= pf.label :avatar_url %><br />
      <%= pf.url_field :avatar_url, autocomplete: "url" %>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :password, t("devise.registrations.edit.password", default: "Новый пароль") %>
    <i><%= t("devise.registrations.edit.leave_blank_if_you_don_t_want_to_change_it", default: "оставьте пустым, если не хотите менять") %></i><br />
    <%= f.password_field :password, autocomplete: "new-password" %>
    <% if @minimum_password_length %>
      <br />
      <em><%= t("devise.shared.minimum_password_length", count: @minimum_password_length, default: "#{@minimum_password_length} символов минимум") %></em>
    <% end %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :current_password %>
    <i><%= t("devise.registrations.edit.we_need_your_current_password_to_confirm_your_changes", default: "нужен для подтверждения изменений") %></i><br />
    <%= f.password_field :current_password, autocomplete: "current-password" %>
  </div>

  <div class="actions">
    <%= f.submit t("devise.registrations.edit.update", default: "Сохранить изменения") %>
  </div>
<% end %>

<h3><%= t("devise.registrations.edit.cancel_my_account", default: "Удалить аккаунт") %></h3>

<div>
  <%= button_to t("devise.registrations.edit.cancel_my_account", default: "Удалить аккаунт"), registration_path(resource_name), data: { confirm: t("devise.registrations.edit.are_you_sure", default: "Вы уверены?"), turbo_confirm: t("devise.registrations.edit.are_you_sure", default: "Вы уверены?") }, method: :delete %>
</div>

<%= link_to t("devise.shared.links.back", default: "Назад"), root_path %>
