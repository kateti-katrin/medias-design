<h2><%= t("devise.passwords.new.forgot_your_password", default: "Забыли пароль?") %></h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div class="actions">
    <%= f.submit t("devise.passwords.new.send_me_reset_password_instructions", default: "Отправить инструкции по сбросу пароля") %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
