<% content_for :title, "Читать — СМЫСЛ" %>
<% set_meta_tags(
  description: "Подборка материалов «Смысл» о задаче, оценке, бюджете и процессе работы с дизайном.",
  canonical: articles_url,
  og: {
    type: "website",
    image: "article-large.png"
  }
) %>

<div class="bg-grid" aria-hidden="true">
  <%= image_tag "bg-decoration.svg", alt: "" %>
</div>

<div class="articles-pg-wrap">
  <% article_by_tag = @articles.index_by(&:tag) %>
  <% article_task = article_by_tag["задача"] || @articles[0] %>
  <% article_eval = article_by_tag["оценка"] || @articles[1] %>
  <% article_money = article_by_tag["деньги"] || @articles[2] %>
  <% article_process = article_by_tag["процесс"] || @articles[3] %>

  <%# ── Header ── %>
  <div class="articles-pg-head">
    <%= link_to "← на главную", root_path, class: "articles-pg-back" %>
    <h1 class="articles-pg-title">Читать</h1>
  </div>

  <%# ── Filters ── %>
  <div class="articles-pg-filters" role="group" aria-label="Фильтр по темам">
    <button class="articles-pg-filter is-active" data-filter="all">Все материалы</button>
    <button class="articles-pg-filter" data-filter="задача">[ задача ]</button>
    <button class="articles-pg-filter" data-filter="оценка">[ оценка ]</button>
    <button class="articles-pg-filter" data-filter="деньги">[ деньги ]</button>
    <button class="articles-pg-filter" data-filter="процесс">[ процесс ]</button>
  </div>

  <%# ── Cards — same structure and classes as home page ── %>
  <div class="articles">

    <div class="articles-row">

      <%= link_to article_path(article_task), class: "article-card article-card--large", data: { tag: "задача" } do %>
        <div class="article-img article-img--large">
          <div class="article-img__photo">
            <%= image_tag(article_task&.image || "article-large.png", alt: article_task&.title.to_s) %>
          </div>
          <div class="article-img__overlay" aria-hidden="true">
            <%= image_tag "article-large-overlay.png", alt: "" %>
            <div class="article-img__tint"></div>
          </div>
        </div>
        <div class="article-card__body article-card__body--large">
          <p class="article-card__tag">[ <%= article_task&.tag || "задача" %> ]</p>
          <p class="article-card__title"><%= article_task&.title || "Как поставить задачу дизайнеру, чтобы не переделывать 3 раза" %></p>
        </div>
      <% end %>

      <%= link_to article_path(article_eval), class: "article-card article-card--small", data: { tag: "оценка" } do %>
        <div class="article-img article-img--small">
          <div class="article-img__photo">
            <%= image_tag(article_eval&.image || "article-small.png", alt: article_eval&.title.to_s) %>
          </div>
          <div class="article-img__overlay" aria-hidden="true">
            <%= image_tag "article-small-overlay.png", alt: "" %>
            <div class="article-img__gradient"></div>
          </div>
        </div>
        <div class="article-card__body">
          <p class="article-card__tag">[ <%= article_eval&.tag || "оценка" %> ]</p>
          <p class="article-card__title"><%= article_eval&.title || "Что ломает лендинг ещё до первого экрана" %></p>
        </div>
      <% end %>

    </div>

    <div class="articles-row">

      <%= link_to article_path(article_money), class: "article-card article-card--small", data: { tag: "деньги" } do %>
        <div class="article-img article-img--small article-img--simple">
          <div class="article-img__photo">
            <%= image_tag(article_money&.image || "article-small.png", alt: article_money&.title.to_s) %>
          </div>
        </div>
        <div class="article-card__body">
          <p class="article-card__tag">[ <%= article_money&.tag || "деньги" %> ]</p>
          <p class="article-card__title"><%= article_money&.title || "Почему один и тот же сайт стоит по-разному" %></p>
        </div>
      <% end %>

      <%= link_to article_path(article_process), class: "article-card article-card--large", data: { tag: "процесс" } do %>
        <div class="article-img article-img--large article-img--simple">
          <div class="article-img__photo">
            <%= image_tag(article_process&.image || "article-large.png", alt: article_process&.title.to_s) %>
          </div>
        </div>
        <div class="article-card__body article-card__body--large">
          <p class="article-card__tag">[ <%= article_process&.tag || "процесс" %> ]</p>
          <p class="article-card__title"><%= article_process&.title || "Почему правки в дизайне съедают сроки и результат" %></p>
        </div>
      <% end %>

    </div>

  </div>

</div>

<%# ── Footer — full-width, same as home page ── %>
<footer class="site-footer">
  <div class="site-footer__logo">
    <%= image_tag "logo-smysl-footer.svg", alt: "СМЫСЛ" %>
  </div>
  <p class="site-footer__tagline">Пишем о продающем визуале</p>
  <nav class="site-footer__nav" aria-label="Навигация в подвале">
    <%= link_to "главная",  root_path,                class: "site-nav__link" %>
    <%= link_to "Статьи",   articles_path,            class: "site-nav__link" %>
    <%= link_to "Задача",   brief_services_path,      class: "site-nav__link" %>
    <%= link_to "бюджет",   calculator_services_path, class: "site-nav__link" %>
    <%= link_to "о нас",    root_path(anchor: "about"), class: "site-nav__link" %>
  </nav>
</footer>
