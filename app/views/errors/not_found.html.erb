<% content_for :title, "404 — СМЫСЛ" %>

<%= content_for :head do %>
<style>
  .err-wrap {
    width: 100%;
    min-height: calc(100vh - var(--h-footer));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--gap-section) 0;
    gap: var(--gap-element);
  }

  .err-inner {
    width: var(--w-content);
    display: flex;
    flex-direction: column;
    gap: var(--gap-element);
  }

  .err-number {
    font-family: 'Bounded', system-ui, sans-serif;
    font-size: clamp(120px, 22vw, 320px);
    line-height: 0.85;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
    opacity: 0.08;
    user-select: none;
    pointer-events: none;
    position: absolute;
    left: 2.083vw;
  }

  .err-content {
    width: var(--w-content);
    display: flex;
    flex-direction: column;
    gap: var(--gap-tight);
    position: relative;
    z-index: 1;
    padding-top: clamp(80px, 11vw, 160px);
  }

  .err-title {
    font-family: 'Bounded', system-ui, sans-serif;
    font-size: clamp(36px, 5.556vw, 80px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
    max-width: 70%;
  }

  .err-sub {
    font-family: 'Inter', sans-serif;
    font-size: var(--fs-body-md);
    line-height: 1.4;
    color: var(--color-text);
    opacity: 0.55;
    max-width: 460px;
    margin: 0;
  }

  .err-cta {
    margin-top: calc(var(--gap-element) * 0.5);
  }

  @media (max-width: 1024px) {
    .err-number { font-size: clamp(100px, 18vw, 240px); }
    .err-title  { max-width: 90%; }
    .err-content { width: calc(100% - 40px); }
  }

  @media (max-width: 640px) {
    .err-wrap { min-height: 70vh; padding: 80px 0 60px; }
    .err-number { font-size: clamp(80px, 28vw, 160px); left: 12px; }
    .err-content { width: calc(100% - 24px); padding-top: 90px; }
    .err-title { font-size: clamp(28px, 7vw, 48px); max-width: 100%; }
    .err-sub { font-size: 16px; }
  }
</style>
<% end %>

<div class="bg-grid" aria-hidden="true">
  <%= image_tag "bg-decoration.svg", alt: "" %>
</div>

<div class="err-wrap">
  <p class="err-number" aria-hidden="true">404</p>

  <div class="err-content">
    <h1 class="err-title">Страница пропала без объяснений</h1>
    <p class="err-sub">Как дизайн без брифа — что-то, возможно, и было, но непонятно что и зачем.</p>
    <div class="err-cta">
      <%= link_to "← На главную", root_path, class: "btn btn--primary" %>
    </div>
  </div>
</div>

<footer class="site-footer">
  <div class="site-footer__logo">
    <%= image_tag "logo-smysl-footer.svg", alt: "СМЫСЛ" %>
  </div>
  <p class="site-footer__tagline">Пишем о продающем визуале</p>
  <nav class="site-footer__nav" aria-label="Навигация в подвале">
    <%= link_to "главная",  root_path,                class: "site-nav__link" %>
    <%= link_to "Статьи",   articles_path,            class: "site-nav__link" %>
    <%= link_to "Задача",   brief_services_path,      class: "site-nav__link" %>
    <%= link_to "бюджет",   calculator_services_path, class: "site-nav__link" %>
    <%= link_to "о нас",    "#",                      class: "site-nav__link" %>
  </nav>
</footer>
