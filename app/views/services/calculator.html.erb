<% content_for :title, "Калькулятор бюджета — СМЫСЛ" %>

<div class="tool-page">
  <header class="tool-page__header">
    <%= link_to "← на главную", root_path, class: "tool-page__back" %>
    <h1 class="tool-page__title">Калькулятор бюджета</h1>
    <p class="tool-page__lead">Выберите параметры проекта и получите ориентир по бюджету и срокам.</p>
  </header>

  <section class="tool-card" id="budget-calculator" aria-label="Калькулятор бюджета">
    <form class="tool-form" id="budget-form">
      <label class="tool-field">
        <span>Тип проекта</span>
        <select name="type" required>
          <option value="landing">Лендинг</option>
          <option value="corporate">Корпоративный сайт</option>
          <option value="shop">Интернет-магазин</option>
          <option value="presentation">Презентация</option>
        </select>
      </label>

      <label class="tool-field">
        <span>Количество ключевых экранов/страниц</span>
        <input type="number" name="pages" min="1" max="30" value="5" required>
      </label>

      <label class="tool-field tool-field--checkbox">
        <input type="checkbox" name="brandbook">
        <span>Нужна разработка фирменного стиля / mini-brandbook</span>
      </label>

      <label class="tool-field tool-field--checkbox">
        <input type="checkbox" name="copywriting">
        <span>Нужна помощь с текстами (редактура/написание)</span>
      </label>

      <label class="tool-field tool-field--checkbox">
        <input type="checkbox" name="analytics">
        <span>Нужен анализ конкурентов и структуры</span>
      </label>

      <label class="tool-field">
        <span>Срочность</span>
        <select name="urgency" required>
          <option value="normal">Стандартный срок</option>
          <option value="fast">Нужно быстрее обычного</option>
          <option value="rush">Очень срочно</option>
        </select>
      </label>

      <button type="submit" class="btn btn--primary tool-submit">Рассчитать</button>
    </form>

    <div class="tool-result" id="budget-result" hidden>
      <div class="tool-result__head">
        <h2>Ориентир бюджета</h2>
        <button type="button" class="btn btn--about" id="budget-copy">Скопировать</button>
      </div>
      <pre id="budget-output"></pre>
      <p class="tool-result__note">Это предварительная оценка, финальная смета зависит от деталей задачи.</p>
    </div>
  </section>
</div>
